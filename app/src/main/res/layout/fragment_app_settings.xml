<?xml version="1.0" encoding="utf-8" ?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
>

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@android:color/transparent"
        android:elevation="0dp"
    >

        <com.google.android.material.appbar.CollapsingToolbarLayout
            android:id="@+id/fragment_header_collapsing_toolbar"
            android:layout_width="match_parent"
            android:layout_height="132dp"
            android:background="@android:color/transparent"
            app:collapsedTitleGravity="start|center_vertical"
            app:collapsedTitleTextAppearance="@style/TextAppearance.DeviceSpoofLab.CollapsingCollapsed"
            app:contentScrim="?attr/colorSurfaceVariant"
            app:expandedTitleMarginStart="20dp"
            app:expandedTitleMarginEnd="20dp"
            app:expandedTitleMarginBottom="16dp"
            app:expandedTitleTextAppearance="@style/TextAppearance.DeviceSpoofLab.CollapsingExpanded"
            app:layout_scrollFlags="scroll|exitUntilCollapsed|snap"
            app:statusBarScrim="@android:color/transparent"
            app:title="@string/toolbar_app_settings"
        >

            <com.google.android.material.appbar.MaterialToolbar
                android:layout_width="match_parent"
                android:layout_height="?attr/actionBarSize"
                android:background="@android:color/transparent"
                app:layout_collapseMode="pin"
            />
        </com.google.android.material.appbar.CollapsingToolbarLayout>
    </com.google.android.material.appbar.AppBarLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:paddingStart="20dp"
        android:paddingTop="16dp"
        android:paddingEnd="20dp"
        android:paddingBottom="112dp"
        app:layout_behavior="@string/appbar_scrolling_view_behavior"
    >

    <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
        >

        <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/settings_diagnostics_title"
                android:textAllCaps="true"
                android:textColor="?attr/colorOnSurfaceVariant"
                android:textSize="12sp"
                android:textStyle="bold"
            />

        <LinearLayout
                android:id="@+id/open_real_info_row"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:background="?attr/selectableItemBackground"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground"
                android:gravity="center_vertical"
                android:minHeight="72dp"
                android:orientation="horizontal"
                android:paddingTop="14dp"
                android:paddingBottom="14dp"
            >

            <ImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:contentDescription="@null"
                    android:src="@drawable/ic_settings_diagnostics"
                    app:tint="?attr/colorOnSurfaceVariant"
                />

            <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:layout_marginEnd="16dp"
                    android:layout_weight="1"
                    android:orientation="vertical"
                >

                <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/settings_real_info_title"
                        android:textColor="?attr/colorOnSurface"
                        android:textSize="16sp"
                    />

                <TextView
                        android:id="@+id/real_info_summary"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text="@string/settings_real_info_summary"
                        android:textColor="?attr/colorOnSurfaceVariant"
                        android:textSize="13sp"
                    />
            </LinearLayout>

            <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:contentDescription="@null"
                    android:src="@drawable/ic_settings_chevron"
                    app:tint="?attr/colorOutline"
                />
        </LinearLayout>

        <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="28dp"
                android:text="@string/settings_presets_title"
                android:textAllCaps="true"
                android:textColor="?attr/colorOnSurfaceVariant"
                android:textSize="12sp"
                android:textStyle="bold"
            />

        <LinearLayout
                android:id="@+id/preset_source_row"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:background="?attr/selectableItemBackground"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground"
                android:gravity="center_vertical"
                android:minHeight="72dp"
                android:orientation="horizontal"
                android:paddingTop="14dp"
                android:paddingBottom="14dp"
            >

            <ImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:contentDescription="@null"
                    android:src="@drawable/ic_settings_source"
                    app:tint="?attr/colorOnSurfaceVariant"
                />

            <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:layout_weight="1"
                    android:orientation="vertical"
                >

                <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/settings_preset_source_title"
                        android:textColor="?attr/colorOnSurface"
                        android:textSize="16sp"
                    />

                <TextView
                        android:id="@+id/preset_source_summary"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:textColor="?attr/colorOnSurfaceVariant"
                        android:textSize="13sp"
                    />
            </LinearLayout>

            <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:contentDescription="@null"
                    android:src="@drawable/ic_settings_chevron"
                    app:tint="?attr/colorOutline"
                />
        </LinearLayout>

        <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="28dp"
                android:text="@string/settings_appearance_title"
                android:textAllCaps="true"
                android:textColor="?attr/colorOnSurfaceVariant"
                android:textSize="12sp"
                android:textStyle="bold"
            />

        <LinearLayout
                android:id="@+id/theme_row"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:background="?attr/selectableItemBackground"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground"
                android:gravity="center_vertical"
                android:minHeight="72dp"
                android:orientation="horizontal"
                android:paddingTop="14dp"
                android:paddingBottom="14dp"
            >

            <ImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:contentDescription="@null"
                    android:src="@drawable/ic_settings_theme"
                    app:tint="?attr/colorOnSurfaceVariant"
                />

            <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:layout_weight="1"
                    android:orientation="vertical"
                >

                <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/settings_theme_title"
                        android:textColor="?attr/colorOnSurface"
                        android:textSize="16sp"
                    />

                <TextView
                        android:id="@+id/theme_summary"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:textColor="?attr/colorOnSurfaceVariant"
                        android:textSize="13sp"
                    />
            </LinearLayout>

            <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:contentDescription="@null"
                    android:src="@drawable/ic_settings_chevron"
                    app:tint="?attr/colorOutline"
                />
        </LinearLayout>

        <LinearLayout
                android:id="@+id/language_row"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="?attr/selectableItemBackground"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground"
                android:gravity="center_vertical"
                android:minHeight="72dp"
                android:orientation="horizontal"
                android:paddingTop="14dp"
                android:paddingBottom="14dp"
            >

            <ImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:contentDescription="@null"
                    android:src="@drawable/ic_settings_language"
                    app:tint="?attr/colorOnSurfaceVariant"
                />

            <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:layout_weight="1"
                    android:orientation="vertical"
                >

                <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/settings_language_title"
                        android:textColor="?attr/colorOnSurface"
                        android:textSize="16sp"
                    />

                <TextView
                        android:id="@+id/language_summary"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:textColor="?attr/colorOnSurfaceVariant"
                        android:textSize="13sp"
                    />
            </LinearLayout>

            <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:contentDescription="@null"
                    android:src="@drawable/ic_settings_chevron"
                    app:tint="?attr/colorOutline"
                />
        </LinearLayout>

        <LinearLayout
                android:id="@+id/system_colors_row"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="?attr/selectableItemBackground"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground"
                android:gravity="center_vertical"
                android:minHeight="72dp"
                android:orientation="horizontal"
                android:paddingTop="14dp"
                android:paddingBottom="14dp"
            >

            <ImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:contentDescription="@null"
                    android:src="@drawable/ic_settings_colors"
                    app:tint="?attr/colorOnSurfaceVariant"
                />

            <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:layout_marginEnd="16dp"
                    android:layout_weight="1"
                    android:orientation="vertical"
                >

                <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/settings_system_colors_title"
                        android:textColor="?attr/colorOnSurface"
                        android:textSize="16sp"
                    />

                <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text="@string/settings_system_colors_summary"
                        android:textColor="?attr/colorOnSurfaceVariant"
                        android:textSize="13sp"
                    />
            </LinearLayout>

            <com.google.android.material.materialswitch.MaterialSwitch
                    android:id="@+id/system_colors_switch"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:saveEnabled="false"
                />
        </LinearLayout>

        <LinearLayout
                android:id="@+id/color_style_row"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="?attr/selectableItemBackground"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground"
                android:gravity="center_vertical"
                android:minHeight="72dp"
                android:orientation="horizontal"
                android:paddingTop="14dp"
                android:paddingBottom="14dp"
                android:visibility="gone"
            >

            <ImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:contentDescription="@null"
                    android:src="@drawable/ic_settings_colors"
                    app:tint="?attr/colorOnSurfaceVariant"
                />

            <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:layout_weight="1"
                    android:orientation="vertical"
                >

                <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/settings_color_style_title"
                        android:textColor="?attr/colorOnSurface"
                        android:textSize="16sp"
                    />

                <TextView
                        android:id="@+id/color_style_summary"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:textColor="?attr/colorOnSurfaceVariant"
                        android:textSize="13sp"
                    />
            </LinearLayout>

            <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:contentDescription="@null"
                    android:src="@drawable/ic_settings_chevron"
                    app:tint="?attr/colorOutline"
                />
        </LinearLayout>

        <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="28dp"
                android:text="@string/settings_runtime_title"
                android:textAllCaps="true"
                android:textColor="?attr/colorOnSurfaceVariant"
                android:textSize="12sp"
                android:textStyle="bold"
            />

        <LinearLayout
                android:id="@+id/resolution_row"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:background="?attr/selectableItemBackground"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground"
                android:gravity="center_vertical"
                android:minHeight="72dp"
                android:orientation="horizontal"
                android:paddingTop="14dp"
                android:paddingBottom="14dp"
            >

            <ImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:contentDescription="@null"
                    android:src="@drawable/ic_settings_resolution"
                    app:tint="?attr/colorOnSurfaceVariant"
                />

            <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:layout_weight="1"
                    android:orientation="vertical"
                >

                <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/settings_resolution_title"
                        android:textColor="?attr/colorOnSurface"
                        android:textSize="16sp"
                    />

                <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text="@string/settings_resolution_summary"
                        android:textColor="?attr/colorOnSurfaceVariant"
                        android:textSize="13sp"
                    />
            </LinearLayout>

            <com.google.android.material.materialswitch.MaterialSwitch
                    android:id="@+id/resolution_switch"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:saveEnabled="false"
                />
        </LinearLayout>

        <LinearLayout
                android:id="@+id/hook_wifi_row"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="?attr/selectableItemBackground"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground"
                android:gravity="center_vertical"
                android:minHeight="72dp"
                android:orientation="horizontal"
                android:paddingTop="14dp"
                android:paddingBottom="14dp"
            >

            <ImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:contentDescription="@null"
                    android:src="@drawable/ic_settings_wifi"
                    app:tint="?attr/colorOnSurfaceVariant"
                />

            <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:layout_marginEnd="16dp"
                    android:layout_weight="1"
                    android:orientation="vertical"
                >

                <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/settings_hook_wifi_title"
                        android:textColor="?attr/colorOnSurface"
                        android:textSize="16sp"
                    />

                <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text="@string/settings_hook_wifi_summary"
                        android:textColor="?attr/colorOnSurfaceVariant"
                        android:textSize="13sp"
                    />
            </LinearLayout>

            <com.google.android.material.materialswitch.MaterialSwitch
                    android:id="@+id/hook_wifi_switch"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:saveEnabled="false"
                />
        </LinearLayout>

        <LinearLayout
                android:id="@+id/hook_location_row"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="?attr/selectableItemBackground"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground"
                android:gravity="center_vertical"
                android:minHeight="72dp"
                android:orientation="horizontal"
                android:paddingTop="14dp"
                android:paddingBottom="14dp"
            >

            <ImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:contentDescription="@null"
                    android:src="@drawable/ic_settings_location"
                    app:tint="?attr/colorOnSurfaceVariant"
                />

            <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:layout_marginEnd="16dp"
                    android:layout_weight="1"
                    android:orientation="vertical"
                >

                <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/settings_hook_location_title"
                        android:textColor="?attr/colorOnSurface"
                        android:textSize="16sp"
                    />

                <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text="@string/settings_hook_location_summary"
                        android:textColor="?attr/colorOnSurfaceVariant"
                        android:textSize="13sp"
                    />
            </LinearLayout>

            <com.google.android.material.materialswitch.MaterialSwitch
                    android:id="@+id/hook_location_switch"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:saveEnabled="false"
                />
        </LinearLayout>

        <LinearLayout
                android:id="@+id/safe_mode_row"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="?attr/selectableItemBackground"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground"
                android:gravity="center_vertical"
                android:minHeight="72dp"
                android:orientation="horizontal"
                android:paddingTop="14dp"
                android:paddingBottom="14dp"
            >

            <ImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:contentDescription="@null"
                    android:src="@drawable/ic_settings_safe_mode"
                    app:tint="?attr/colorOnSurfaceVariant"
                />

            <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:layout_weight="1"
                    android:orientation="vertical"
                >

                <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/settings_safe_mode_title"
                        android:textColor="?attr/colorOnSurface"
                        android:textSize="16sp"
                    />

                <TextView
                        android:id="@+id/safe_mode_summary"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:textColor="?attr/colorOnSurfaceVariant"
                        android:textSize="13sp"
                    />
            </LinearLayout>

            <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:contentDescription="@null"
                    android:src="@drawable/ic_settings_chevron"
                    app:tint="?attr/colorOutline"
                />
        </LinearLayout>
        <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="28dp"
                android:text="@string/settings_proxy_section_title"
                android:textAllCaps="true"
                android:textColor="?attr/colorOnSurfaceVariant"
                android:textSize="12sp"
                android:textStyle="bold"
            />

        <LinearLayout
                android:id="@+id/reset_iptables_row"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:background="?attr/selectableItemBackground"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground"
                android:gravity="center_vertical"
                android:minHeight="72dp"
                android:orientation="horizontal"
                android:paddingTop="14dp"
                android:paddingBottom="14dp"
            >

            <ImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:contentDescription="@null"
                    android:src="@drawable/ic_settings_wifi"
                    app:tint="?attr/colorOnSurfaceVariant"
                />

            <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:layout_weight="1"
                    android:orientation="vertical"
                >

                <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/settings_reset_iptables_title"
                        android:textColor="?attr/colorOnSurface"
                        android:textSize="16sp"
                    />

                <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text="@string/settings_reset_iptables_summary"
                        android:textColor="?attr/colorOnSurfaceVariant"
                        android:textSize="13sp"
                    />
            </LinearLayout>
        </LinearLayout>

    </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</androidx.coordinatorlayout.widget.CoordinatorLayout>
